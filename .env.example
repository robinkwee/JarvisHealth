# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Anthropic API Key (for food photo analysis via Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Apps Script Web App URL (optional — enables Sheets logging)
SHEETS_WEBHOOK=https://script.google.com/macros/s/.../exec

# Daily macro targets (optional — defaults shown)
TARGET_CALORIES=2000
TARGET_PROTEIN=150
TARGET_CARBS=200
TARGET_FAT=65
TARGET_FIBER=25
